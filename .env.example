# ============================================================
# Boss Task Agent - 环境变量模板
# 使用方法：复制本文件为 .env，再填入你自己的值。.env 已在 .gitignore 中排除。
# ============================================================

# ── 必填：LLM API Key ──
# 从对应厂商控制台申请
OPENAI_API_KEY=your-api-key-here

# ── 可选：LLM Base URL ──
# 默认使用阿里云百炼（DashScope）的 OpenAI 兼容端点
# 若切换 Moonshot Kimi：https://api.moonshot.cn/v1
# 若切换 OpenAI 官方：https://api.openai.com/v1
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── 可选：模型名 ──
# 阿里云百炼可用：qwen-plus / qwen-max / qwen-turbo
# Moonshot 可用：moonshot-v1-8k / moonshot-v1-32k
# OpenAI 可用：gpt-4o-mini / gpt-4o
OPENAI_MODEL=qwen-plus

# ── 可选：输入文件路径 ──
# 支持 .xlsx/.mp3/.wav/.m4a；不填则默认读取 ./input/Workbook.xlsx
# BOSS_INPUT_PATH=D:\path\to\your\meeting.m4a

# ── 可选：本地 Whisper 音频转写 ──
# 首次转写会下载模型。可选模型：tiny/base/small/medium/large-v3
BOSS_WHISPER_MODEL=small
# auto 会自动选择 CPU 或可用 GPU
BOSS_WHISPER_DEVICE=auto
BOSS_WHISPER_COMPUTE_TYPE=default
# 中文使用 zh；如需自动识别语言可设为 auto
BOSS_WHISPER_LANGUAGE=zh

# ── 可选：每条输入信息显示的发言人职位 ──
BOSS_SPEAKER_ROLE=老板
