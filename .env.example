# ============================================================
# Boss Task Agent - 环境变量模板
# 使用方法：复制本文件为 .env，再填入你自己的值。.env 已在 .gitignore 中排除。
# ============================================================

# ── 必填：LLM API Key ──
# 从对应厂商控制台申请
OPENAI_API_KEY=your-api-key-here

# ── 可选：LLM Base URL ──
# 默认使用阿里云百炼（DashScope）的 OpenAI 兼容端点
# 若切换 Moonshot Kimi：https://api.moonshot.cn/v1
# 若切换 OpenAI 官方：https://api.openai.com/v1
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── 可选：模型名 ──
# 阿里云百炼可用：qwen-plus / qwen-max / qwen-turbo
# Moonshot 可用：moonshot-v1-8k / moonshot-v1-32k
# OpenAI 可用：gpt-4o-mini / gpt-4o
OPENAI_MODEL=qwen-plus

# ── 可选：输入 Excel 路径 ──
# 不填则默认读取 ./input/Workbook.xlsx
# BOSS_WORKBOOK_PATH=D:\path\to\your\Workbook.xlsx
